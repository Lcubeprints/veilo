# ============================================================================
# VEILO — Environment Variables
# ============================================================================

# Network
NETWORK=testnet
RPC_URL=https://api.explorer.provable.com/v1/testnet

# Contract Program IDs (fill in after deploying)
PROGRAM_ID_ALEO=veilo_market_v1.aleo
PROGRAM_ID_USDCX=veilo_market_usdcx_v1.aleo
PROGRAM_ID_USAD=veilo_market_usad_v1.aleo

# Backend
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
PINATA_JWT=your-pinata-jwt
PORT=3001

# Frontend (prefix with VITE_)
VITE_NETWORK=testnet
VITE_RPC_URL=https://api.explorer.provable.com/v1/testnet
VITE_EXPLORER_URL=https://testnet.explorer.provable.com
VITE_BACKEND_URL=http://localhost:3001
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_PROGRAM_ID_ALEO=veilo_market_v1.aleo
VITE_PROGRAM_ID_USDCX=veilo_market_usdcx_v1.aleo
VITE_PROGRAM_ID_USAD=veilo_market_usad_v1.aleo
VITE_APP_NAME=Veilo