# ============================================================================
# Veilo — .gitignore
# ============================================================================

# Environment secrets — NEVER commit these
.env
.env.local
.env.*.local

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# TypeScript build output
dist/
build/
*.tsbuildinfo

# Vite
frontend/.vite/

# Leo / Aleo build artifacts
contracts/*/build/
contracts/*/outputs/
contracts/*/.env
contracts/**/*.avm
contracts/**/*.prover
contracts/**/*.verifier

# Editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Test coverage
coverage/

# Logs
*.log
logs/

# Supabase local
supabase/.branches/
supabase/.temp/
